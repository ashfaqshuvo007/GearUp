model User {
    id        String        @id @default(uuid())
    name      String        @db.VarChar(255)
    email     String        @unique
    status    ActiveStatus  @default(ACTIVE)
    role      Role          @default(CUSTOMER)
    orders    RentalOrder[]
    reviews   Review[]
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
}
